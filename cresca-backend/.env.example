# ─── Algorand ────────────────────────────────────────────────
# Keeper wallet mnemonic (hot wallet for tx fees only)
# Fund with ~5 ALGO on testnet: https://bank.testnet.algorand.network/
ALGO_KEEPER_MNEMONIC="word1 word2 ... word25"
ALGO_NETWORK=testnet

# ─── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# ─── Expo Push ───────────────────────────────────────────────
EXPO_PUSH_ACCESS_TOKEN=

# ─── Keeper Config ───────────────────────────────────────────
KEEPER_CALENDAR_INTERVAL_MS=30000
KEEPER_ORACLE_INTERVAL_MS=20000
KEEPER_LIQUIDATION_INTERVAL_MS=60000

# ─── Server ──────────────────────────────────────────────────
PORT=3001
LOG_LEVEL=info
